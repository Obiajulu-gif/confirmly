# Confirmly environment template.
# Copy to .env.local and fill in values, or run: npm run secrets:import
# NEVER commit .env.local or real values.

# Application
APP_URL=
# PostgreSQL connection string (unquoted, e.g. postgres://user:pass@host:5432/db?sslmode=require)
DATABASE_URL=
AUTH_SECRET=
# AES-256-GCM key for encrypting settlement bank details at rest
ENCRYPTION_KEY=
RECEIPT_TOKEN_SECRET=
DEMO_MERCHANT_EMAIL=
DEMO_MERCHANT_PASSWORD=

# WhatsApp / Meta
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_VERSION=
# Public display number customers message (used for wa.me links; not a secret)
WHATSAPP_PUBLIC_NUMBER=

# NVIDIA
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_ORDER_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Product-image generation (NVIDIA-hosted FLUX.1-dev; falls back to NVIDIA_API_KEY)
# flux.1-schnell's hosted function hangs for this account; flux.1-dev is provisioned.
NVIDIA_IMAGE_API_KEY=
NVIDIA_IMAGE_BASE_URL=https://ai.api.nvidia.com
NVIDIA_IMAGE_MODEL=black-forest-labs/flux.1-dev
NVIDIA_IMAGE_WIDTH=1024
NVIDIA_IMAGE_HEIGHT=1024
# flux.1-dev requires steps in [5, 50]
NVIDIA_IMAGE_STEPS=25
NVIDIA_IMAGE_CFG_SCALE=3.5
NVIDIA_IMAGE_TIMEOUT_MS=120000
NVIDIA_IMAGE_GENERATION_ENABLED=true
ALLOW_UNAPPROVED_AI_PRODUCT_IMAGES=false
PRODUCT_IMAGE_MAX_BYTES=4194304

# Monnify
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
# Route checkouts through merchant subaccounts (requires the Monnify Sub
# Account feature; when false, payments settle to the platform account with a
# visible dashboard warning)
MONNIFY_SUBACCOUNT_ENABLED=false
MONNIFY_PLATFORM_FEE_PERCENT=0

# Optional
SENTRY_DSN=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Demo mode (see README — never enabled silently)
DEMO_MODE=false

# Platform admin console: comma-separated emails granted access to /admin
# (cross-tenant view + CRUD). Leave blank to disable the console entirely.
ADMIN_EMAILS=

# Abandoned-order nudge: when true, an hourly job sends ONE gentle re-engagement
# to stalled orders inside WhatsApp's 24h window (respects customer opt-in).
# Off by default because it sends real outbound messages.
NUDGE_ENABLED=false

# Vercel Cron authentication
CRON_SECRET=
