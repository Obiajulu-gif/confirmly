# Confirmly environment template.
# Copy to .env.local and fill in values, or run: npm run secrets:import
# NEVER commit .env.local or real values.

# Application
APP_URL=
DATABASE_URL=
AUTH_SECRET=
RECEIPT_TOKEN_SECRET=
DEMO_MERCHANT_EMAIL=
DEMO_MERCHANT_PASSWORD=

# WhatsApp / Meta
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_VERSION=

# NVIDIA
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_ORDER_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Monnify
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=

# Optional
SENTRY_DSN=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Demo mode (see README — never enabled silently)
DEMO_MODE=false
