{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run vercel-build",
  "env": {
    "APP_URL": "https://confirmly-alpha.vercel.app"
  },
  "crons": [
    {
      "path": "/api/product-images/prewarm",
      "schedule": "45 0 * * *"
    },
    {
      "path": "/api/payments/reconcile",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/conversations/nudge",
      "schedule": "0 * * * *"
    }
  ]
}
